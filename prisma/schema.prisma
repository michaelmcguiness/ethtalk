generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  address        String   @unique
  ensName        String?
  joinedAt       DateTime @default(now())
  lastVerifiedAt DateTime @default(now())
  balanceTier    Int      @default(0)
  bio            String?  @db.Text
  isBanned       Boolean  @default(false)
  role           Role     @default(MEMBER)

  threads        Thread[]
  posts          Post[]
  votes          Vote[]
  threadVotes    ThreadVote[]
  sponsoredLinks SponsoredLink[]
  adFlags        AdFlag[]

  @@index([address])
}

model Thread {
  id        String   @id @default(cuid())
  title     String
  url       String?
  body      String   @db.Text
  tag       Tag?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isPinned  Boolean  @default(false)
  isLocked  Boolean  @default(false)
  viewCount Int      @default(0)

  author      User         @relation(fields: [authorId], references: [id])
  authorId    String
  posts       Post[]
  threadVotes ThreadVote[]

  @@index([createdAt])
  @@index([authorId])
}

model ThreadVote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user     User   @relation(fields: [userId], references: [id])
  userId   String
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String

  @@unique([userId, threadId])
}

model Post {
  id        String   @id @default(cuid())
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isEdited  Boolean  @default(false)

  author   User   @relation(fields: [authorId], references: [id])
  authorId String
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String

  parentId String?
  parent   Post?   @relation("PostReplies", fields: [parentId], references: [id])
  replies  Post[]  @relation("PostReplies")

  votes Vote[]

  @@index([threadId, createdAt])
  @@index([authorId])
}

model Vote {
  id        String   @id @default(cuid())
  value     Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  @@unique([userId, postId])
}

enum Role {
  MEMBER
  MODERATOR
  ADMIN
}

enum Tag {
  PROTOCOL
  DEFI
  L2S
  DEV
  GENERAL
}

model SponsoredLink {
  id           String   @id @default(cuid())
  title        String
  url          String
  domain       String
  date         DateTime @unique
  isActive     Boolean  @default(true)
  isFlagged    Boolean  @default(false)
  flagCount    Int      @default(0)

  buyerAddress String
  buyer        User     @relation(fields: [buyerAddress], references: [address])

  txHash       String   @unique
  pricePaidWei String

  impressions  Int      @default(0)
  clicks       Int      @default(0)

  createdAt    DateTime @default(now())

  events       AdEvent[]
  flags        AdFlag[]

  @@index([date])
  @@index([buyerAddress])
}

model AdEvent {
  id              String        @id @default(cuid())
  sponsoredLinkId String
  sponsoredLink   SponsoredLink @relation(fields: [sponsoredLinkId], references: [id])
  userAddress     String
  eventType       String
  date            DateTime
  createdAt       DateTime      @default(now())

  @@unique([sponsoredLinkId, userAddress, eventType, date])
  @@index([sponsoredLinkId, eventType])
}

model AdFlag {
  id              String        @id @default(cuid())
  sponsoredLinkId String
  sponsoredLink   SponsoredLink @relation(fields: [sponsoredLinkId], references: [id])
  flaggerAddress  String
  flagger         User          @relation(fields: [flaggerAddress], references: [address])
  reason          String?
  createdAt       DateTime      @default(now())

  @@unique([sponsoredLinkId, flaggerAddress])
}

model PendingRefund {
  id           String   @id @default(cuid())
  txHash       String
  buyerAddress String
  amountWei    String
  reason       String
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}
